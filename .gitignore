# Secrets - NEVER commit
.env
.env.local
*.env

# Local config with hostnames/users (sensitive but not secret)
vm_ssh_hosts.json
_vm_ssh_audit.log
_host_ssh_audit.log

# Root-level ad-hoc test / probe scripts and their outputs.
# Anything matching /_*.{py,txt,log} in the repo root is treated as
# scratch space and not committed. Package files under proxmox_mcp/
# starting with __ (dunder) are unaffected.
/_*.py
/_*.txt
/_*.log

