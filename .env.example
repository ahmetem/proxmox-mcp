PROXMOX_HOST=192.168.1.X
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=mcp-server
PROXMOX_TOKEN_VALUE=PASTE-YOUR-TOKEN-SECRET-HERE
PROXMOX_VERIFY_SSL=false
PROXMOX_TIMEOUT=30

# --- Optional: SSH access -------------------------------------------------
# Some Proxmox endpoints (notably `wipedisk` and `initgpt`) reject API tokens
# and require root@pam interactive auth. SSH-backed tools work around this by
# running shell commands directly on the node. Enable only what you need.
#
# PROXMOX_SSH_HOST defaults to PROXMOX_HOST.
# Prefer key auth over password. If both are set, key is used.
# PROXMOX_SSH_KNOWN_HOSTS should point at a file containing the node's host
# key; set to "ignore" only on a trusted local network.
PROXMOX_SSH_HOST=
PROXMOX_SSH_PORT=22
PROXMOX_SSH_USER=root
PROXMOX_SSH_KEY_PATH=
PROXMOX_SSH_KNOWN_HOSTS=
PROXMOX_SSH_PASSWORD=
PROXMOX_SSH_TIMEOUT=30
